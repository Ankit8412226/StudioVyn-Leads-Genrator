# Server
PORT=5000
MONGODB_URI=
LOG_LEVEL=info

# Fireworks AI
FIREWORKS_API_KEY=
FIREWORKS_TEXT_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct
FIREWORKS_CHAT_ENDPOINT=https://api.fireworks.ai/inference/v1/chat/completions
FIREWORKS_IMAGE_MODEL=accounts/fireworks/models/flux-1-schnell-fp8
FIREWORKS_IMAGE_ENDPOINT=https://api.fireworks.ai/inference/v1/workflows/accounts/fireworks/models/flux-1-schnell-fp8/text_to_image
GENERATED_ASSETS_DIR=generated-assets
PUBLIC_WEB_URL=http://localhost:3000
ENABLE_FOLLOW_UP_SCHEDULER=true
FOLLOW_UP_DELAY_HOURS=48
FOLLOW_UP2_DELAY_HOURS=96
FOLLOW_UP_POLL_INTERVAL_SEC=60

# WhatsApp Web
WA_SESSION_PATH=.wa-session
WA_HEADLESS=true
WA_PUPPETEER_EXECUTABLE_PATH=
DEFAULT_COUNTRY_CODE=91

# Queue / Redis
REDIS_URL=redis://127.0.0.1:6379
